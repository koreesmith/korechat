# KoreChat Server Configuration

# Server
HTTP_ADDR=:8080
WS_PATH=/ws
SERVER_NAME=localhost
SERVER_VERSION=KoreChat/1.0
MOTD=Welcome to KoreChat · IRCv3 · Built for teams

# Auth — CHANGE THIS in production (use: openssl rand -hex 32)
JWT_SECRET=changeme-use-a-long-random-string-in-production

# Postgres — matches docker-compose defaults
DATABASE_URL=postgres://korechat:CHANGEME@postgres:5432/korechat?sslmode=disable

# Developer — set to true to log raw IRC lines (← recv / → send) in docker compose logs
IRC_DEBUG=false

# Frontend — host port the nginx frontend is exposed on
FRONTEND_PORT=80
